[Unit]
Description=xMixing FastAPI Backend (port 8001)
After=network.target docker.service mysql.service
Wants=docker.service

[Service]
Type=simple
User=x-root
Group=x-root
WorkingDirectory=/home/x-root/xApp/x2512001-mitrPhol-r02-SPP/x02-backEnd/x0201-fastAPI
ExecStart=/usr/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5
StandardOutput=append:/home/x-root/xApp/x2512001-mitrPhol-r02-SPP/backend.log
StandardError=append:/home/x-root/xApp/x2512001-mitrPhol-r02-SPP/backend.log

[Install]
WantedBy=multi-user.target
